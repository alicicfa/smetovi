---
import { getCollection } from "astro:content";
import "../../styles/global.css";
import PageLayout from "../../layouts/PageLayout.astro";
import { getLangFromCookie } from "../../i18n/server";
import { t } from "../../i18n";

const lang = getLangFromCookie(Astro.cookies.get("lang")?.value);
const tr = t(lang);

const posts = await getCollection("organizations");

function isOpen(workHours: string): boolean | null {
  if (!workHours.includes("-")) return null;
  
  const [openTime, closeTime] = workHours
      .split("-")
      .map((time) => parseInt(time));
      
  if (isNaN(openTime) || isNaN(closeTime)) return null;

  const currentHour = new Date().getHours();
  return currentHour >= openTime && currentHour < closeTime;
}
---

<PageLayout>
  <main class="pt-24">
    <section>
      <ul class="space-y-6">
        {
          posts.map((post) => {
            const postIsOpen = isOpen(post.data.workHours);
            return (
              <li>
                <a href={`/organizations/${post.slug}/`}>
                  <div class="organization flex flex-col md:flex-row w-4/5 mx-auto bg-white shadow-lg overflow-hidden">
                    <div class="org-image flex-none md:w-1/4 h-48 md:h-auto">
                      <img
                          src={post.data.heroImage}
                          alt=""
                          class={`object-cover w-full h-full ${postIsOpen === false ? "filter grayscale" : ""}`}
                      />
                    </div>
                    <div class="org-content flex flex-col justify-center items-start flex-grow p-4">
                      <h4 class="title font-exo2 text-lg sm:text-base md:text-xl lg:text-2xl xl:text-3xl font-bold">
                        {post.data.title}
                      </h4>
                      <h5 class="text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl text-gray-600">
                        {tr.organizations.work_hours}: {post.data.workHours}
                      </h5>
                      <h5
                          class={`text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl font-bold 
                        ${postIsOpen === null ? "text-gray-500" : (postIsOpen ? "text-pastel-green" : "text-tomato-red")}`}
                      >
                        {postIsOpen === null ? tr.organizations.unknown : (postIsOpen ? tr.organizations.open : tr.organizations.closed)}
                      </h5>
                    </div>
                  </div>
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>
  </main>
</PageLayout>