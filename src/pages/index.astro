---
import PageLayout from "../layouts/PageLayout.astro";
import { getLangFromCookie } from "../i18n/server";
import { t } from "../i18n";

const lang = getLangFromCookie(Astro.cookies.get("lang")?.value);
const tr = t(lang);
---

<PageLayout>
  <main id="main" class="landing-background">
    <img id="logo" src="/smetovi-logo.png" alt={tr.index.hero_alt} srcset="" />
  </main>
  <!-- Monument -->
  <div class="flex max-sm:flex-col lg:h-screen overflow-hidden observed">
    <div class="relative w-3/5 max-sm:w-screen fade slide-left">
      <img
          src="/tmp-images/Monument_s.jpg"
          alt=""
          width="100%"
          class="z-0 h-full w-full object-cover"
          style="filter: brightness(1.5);"
      />
      <div class="absolute inset-0 bg-gradient-to-r max-sm:bg-gradient-to-b from-transparent from-50% to-white"></div>
    </div>
    <div class="relative w-2/5 max-sm:w-screen z-10 items-center -ml-20 max-sm:ml-0 mt-[120px] max-sm:-mt-40 text-blue-950 max-sm:p-4 fade slide-bottom">
      <h1 class="text-3xl font-exo2 font-bold mb-2 text-blue-950">{tr.index.section1_title}</h1>
      <div class="ttl-sep w-20 h-1 bg-orange-500 my-2"></div>
      <p class="mt-5 text-[18px]">{tr.index.section1_p1}</p>
      <p class="mt-4 text-[18px]">{tr.index.section1_p2}</p>

     <div class="flex flex-wrap gap-4 mt-5">
        <a href="/map">
          <button
              class="bg-blue-950 px-10 py-2 text-white"
              style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));"
          >
            {tr.index.section1_btn}
          </button>
        </a>

        <a href="/spomenik">
          <button
              class="bg-orange-500 px-10 py-2 text-white font-bold hover:bg-orange-600 transition-colors"
              style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));"
          >
            Više o spomeniku
          </button>
        </a>
      </div>

    </div>
  </div>
  <!-- Flora and fauna -->
  <div class="flex max-sm:flex-col-reverse lg:h-screen overflow-hidden observed">
    <div class="relative w-2/5 max-sm:w-screen z-10 items-center ml-20 -mr-20 max-sm:ml-0 max-sm:mr-0 mt-[120px] max-sm:-mt-40 text-blue-950 max-sm:p-4 fade slide-bottom">
      <h1 class="text-3xl font-exo2 font-bold mb-2 text-blue-950">{tr.index.section2_title}</h1>
      <div class="ttl-sep w-20 h-1 bg-orange-500 my-2"></div>
      <p class="mt-5 text-[18px]">{tr.index.section2_p1}</p>
      <p class="mt-4 text-[18px]">{tr.index.section2_p2}</p>
      <a href="/organizations">
        <button
            class="bg-blue-950 px-10 py-2 mt-5 text-white"
            style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));"
        >
          {tr.index.section2_btn}
        </button>
      </a>
    </div>
    <div class="relative w-3/5 max-sm:w-screen fade slide-right">
      <picture>
        <source media="(max-width: 640px)" srcset="/tmp-images/Fox_s.jpg" />
        <source media="(min-width: 641px)" srcset="/tmp-images/Fox.jpg" />
        <img
            src="/tmp-images/Fox.jpg"
            alt=""
            width="100%"
            class="z-0 h-full w-full object-cover"
            style="transform: scaleX(-1);"
        />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-l max-sm:bg-gradient-to-b from-transparent from-50% to-white"></div>
    </div>
  </div>
</PageLayout>

<style>
  .landing-background {
    background-image: url("/landing-image.png");
    background-size: cover;
    background-position: center;
    height: 100vh;
    width: 100vw;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  main img { max-width: 100; height: auto; }
  .fade { opacity: 0; transition: all 1s ease; }
  @media (prefers-reduced-motion) { .fade { transition: none; } }
  .slide-left { transform: translateX(-50px); }
  .slide-right { transform: translateX(50px); }
  .slide-bottom { transform: translateY(50px); }
  .show { opacity: 1; transform: translateX(0); }
</style>

<script>
  const main = document.getElementById("main");
  const logo = document.getElementById("logo");

  const logoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          let ratio = entry.intersectionRatio;
          let opacity = (ratio - 0.5) / 0.5;
          opacity = Math.max(0, Math.min(1, opacity));
          if (logo != null) logo.style.opacity = opacity.toString();
        });
      },
      { threshold: Array.from({ length: 101 }, (_, i) => i / 100) }
  );
  if (main != null) logoObserver.observe(main);

  const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.firstElementChild?.classList.add("show");
            entry.target.lastElementChild?.classList.add("show");
          } else {
            entry.target.firstElementChild?.classList.remove("show");
            entry.target.lastElementChild?.classList.remove("show");
          }
        });
      },
      { threshold: 0.4 }
  );

  const observedElements = document.querySelectorAll(".observed");
  observedElements.forEach((el) => observer.observe(el));
</script>